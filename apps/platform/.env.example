APP_NAME=OmniBridge
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Docker/local default uses PostgreSQL.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=omnibridge
DB_USERNAME=omnibridge
DB_PASSWORD=omnibridge

# For simple Mac local testing without Docker PostgreSQL, you can use SQLite:
# DB_CONNECTION=sqlite
# Then create apps/platform/database/database.sqlite before running migrations.

QUEUE_CONNECTION=redis
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=database

OMNIBRIDGE_ENVIRONMENT=staging
OMNIBRIDGE_ALLOW_PRODUCTION_WRITES=false
OMNIBRIDGE_ALLOW_CONNECTION_TEST_HTTP=false
OMNIBRIDGE_REDACT_LOG_SECRETS=true
FRONT_SYSTEMS_BASE_URL=https://frontsystemsapis.frontsystems.no/restapi/V2

# Do not put real credentials in this file.
# Store merchant credentials encrypted in the database after setup.
