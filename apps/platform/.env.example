APP_NAME=OmniBridge
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=omnibridge
DB_USERNAME=omnibridge
DB_PASSWORD=omnibridge

QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=database

OMNIBRIDGE_ENVIRONMENT=staging
OMNIBRIDGE_ALLOW_PRODUCTION_WRITES=false
OMNIBRIDGE_REDACT_LOG_SECRETS=true

# Do not put real credentials in this file.
# Store merchant credentials encrypted in the database after setup.

